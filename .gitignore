# Build artifacts
**/node_modules/
**/dist/
**/target/
**/gen/
**/*.tsbuildinfo

# Floater frontend is source (handwritten HTML embedded by Tauri at build time),
# not a build artifact. Override the **/dist/ rule above for this one path.
!packages/floater/dist/
!packages/floater/dist/**

# Tauri / Cargo
packages/floater/Cargo.lock
packages/floater/target/
packages/floater/gen/

# OS / editor
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Local logs
*.log
/tmp/

# Test artifacts
**/coverage/

# Release artifacts (handled separately, not in git)
release/
*.dmg
*.app.zip
