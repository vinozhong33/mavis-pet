{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mavis-pet",
  "version": "0.1.0",
  "identifier": "dev.mavis.pet.floater",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "mavis-pet",
        "width": 140,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": false,
        "shadow": false,
        "skipTaskbar": false,
        "fullscreen": false,
        "center": true,
        "acceptFirstMouse": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "category": "DeveloperTool",
    "icon": [
      "icons/icon.png"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0"
    }
  }
}
